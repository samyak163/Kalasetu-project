{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(node *)",
      "WebSearch"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Read(secrets/**)",
      "Edit(secrets/**)",
      "Write(secrets/**)",
      "Read(credentials/**)",
      "Edit(credentials/**)",
      "Write(credentials/**)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.cert)",
      "Edit(**/*.key)",
      "Edit(**/*.pem)",
      "Edit(**/*.cert)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/*.cert)",
      "Read(credentials.json)",
      "Edit(credentials.json)",
      "Write(credentials.json)",
      "Read(serviceAccountKey.json)",
      "Edit(serviceAccountKey.json)",
      "Write(serviceAccountKey.json)",
      "Edit(package-lock.json)",
      "Write(package-lock.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/dangerous-command-guard.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Context is about to be compacted. Check: 1) Are there in-progress tasks? 2) Were architectural decisions made not yet in docs? 3) Is there debugging context that would be lost? You MUST respond with ONLY valid JSON. If no important state to preserve: {\"decision\":\"approve\"}. If state should be preserved, respond with: {\"decision\":\"approve\",\"systemMessage\":\"PRESERVED CONTEXT: [current task], [key decisions], [stopping point]\"}",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
